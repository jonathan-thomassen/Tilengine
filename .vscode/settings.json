{
  "sonarlint.pathToCompileCommands": "${workspaceFolder}/build/compile_commands.json",
  // clangd: use local LLVM 21 build, point at compile_commands.json in build/
  "clangd.path": "C:\\msys64\\mingw64\\bin\\clangd.exe",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build",
    "--clang-tidy",
    "--header-insertion=never",
    "--background-index"
  ],
  // Disable cpptools IntelliSense so it doesn't conflict with clangd
  "C_Cpp.intelliSenseEngine": "disabled",
  // cppcheck plugin: point at the msys64 binary
  "cppcheck.executePath": "C:\\msys64\\mingw64\\bin\\cppcheck.exe",
  "cppcheck.includePaths": [
    "${workspaceFolder}/src",
    "${workspaceFolder}/include"
  ],
  "cppcheck.standard": [
    "c23"
  ],
  "cppcheck.suppressions": [
    "missingIncludeSystem"
  ]
}